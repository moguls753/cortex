# LLM (required - powers classification and digests)
# Provider: "anthropic" or "openai-compatible"
# For Anthropic: set LLM_API_KEY to your Anthropic API key
# For OpenAI: set LLM_API_KEY, LLM_BASE_URL=https://api.openai.com/v1
# For LM Studio: set LLM_BASE_URL=http://host.docker.internal:1234/v1, LLM_API_KEY=unused
# For Ollama chat: set LLM_PROVIDER=openai-compatible, LLM_BASE_URL=http://ollama:11434/v1
# NOTE: Use host.docker.internal (not localhost) to reach host services from Docker
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=

# Telegram (optional - for bot capture)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (local embeddings - model is pulled automatically on first start)
OLLAMA_MODEL=snowflake-arctic-embed2

# PostgreSQL
POSTGRES_PASSWORD=cortex

# App
PORT=3000
WEBAPP_PASSWORD=cortex
SESSION_SECRET=changeme

# Digest schedule (cron expressions, configurable via Settings page)
DAILY_DIGEST_CRON=30 7 * * *
WEEKLY_DIGEST_CRON=0 16 * * 0

# Email (optional - digests also show on the dashboard)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# DIGEST_EMAIL_TO=you@example.com
# DIGEST_EMAIL_FROM=cortex@example.com
